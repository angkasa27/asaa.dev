---
import FloatingNavigation from "./FloatingNavigation.svelte";
import BaseNavigation from "./BaseNavigation.svelte";
---

<div class="relative min-h-full">
  <script is:inline>
    const mediaQuery = window.matchMedia("(max-width: 767px)");
    const applyMediaState = () => {
      if (!document.body) return;
      document.body.toggleAttribute("data-mobile", mediaQuery.matches);
    };

    applyMediaState();
		mediaQuery.addEventListener("change", applyMediaState);
  </script>

	<div class="relative z-0">
		<slot />
	</div>

	<div class="hidden md:block relative z-50" aria-hidden="true">
		<FloatingNavigation client:load />
	</div>

	<div class="flex md:hidden justify-center fixed left-0 right-0 bottom-4 z-50" aria-hidden="true">
		<BaseNavigation client:load />
	</div>

	<div
		class="md:hidden fixed left-0 right-0 bottom-0 h-16 bg-white/70 dark:bg-[#0a0a0a]/60 backdrop-blur-2xl z-40 pointer-events-none [-webkit-mask-image:linear-gradient(to_top,black,transparent)]"
		aria-hidden="true"
	></div>
</div>
