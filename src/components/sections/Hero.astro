---
import { Image } from "astro:assets";
import avatarImg from "../../assets/avatar.jpeg";
import HeroChips from "./HeroChips.astro";
---

<section
  id="hero"
  class="flex flex-col-reverse sm:flex-row gap-2 justify-between items-center"
>
  <div class="flex flex-col gap-2 items-center sm:items-start">
    <h1
      class="inline-block xl:text-5xl/none text-center sm:text-left animate-on-load"
    >
      Hi! I'm Dimas Angkasa
    </h1>
    <p
      class="text-center sm:text-left text-muted-foreground animate-on-load"
      style="animation-delay: 80ms"
    >
      <!-- Software Engineer | Still fixing some bugs... 👨‍💻 -->
       👨‍💻 Software Engineer | #OpenToWork
    </p>
    <div class="animate-on-load" style="animation-delay: 160ms">
      <HeroChips />
    </div>
  </div>
  <Image
    src={avatarImg}
    alt="Dimas Angkasa"
    width={224}
    height={224}
    format="webp"
    quality={85}
    class="rounded-lg size-28 border-primary border-2 avatar-float animate-on-load"
    loading="eager"
    fetchpriority="high"
  />
</section>
