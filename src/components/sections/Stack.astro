---
import InfiniteSlider from "./InfiniteSlider.svelte";
import { STACK } from "../../constants/stack";


---

<section id="stack" data-reveal>
  <div class="relative max-sm:-mx-6 overflow-hidden">
    <h2 class="sr-only">Stack</h2>
    {
      STACK.map((group, index) => (
        <div class="mb-4">
          <InfiniteSlider
            items={group}
            label="Technology stack"
            durationSeconds={20 + index * 2}
            reverse={index % 2 === 1}
            gapPx={16}
            client:load
          />
        </div>
      ))
    }
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-1/4 bg-linear-to-r from-background"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 w-1/4 bg-linear-to-l from-background"
      aria-hidden="true"
    >
    </div>
  </div>
</section>
