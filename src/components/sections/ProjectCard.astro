---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { Project } from "@/constants/projects";

const { project } = Astro.props as { project: Project };
const { title, description, tags, githubUrl, projectUrl, imageUrl } = project;

const toSlug = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)+/g, "");

const images = import.meta.glob("/src/assets/projects/*.{jpg,jpeg,png,webp}", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

const slug = toSlug(title);
const preferredAssetPath = imageUrl ? `/src/assets${imageUrl}` : null;
const fallbackAssetPaths = [
  `/src/assets/projects/${slug}.jpg`,
  `/src/assets/projects/${slug}.jpeg`,
  `/src/assets/projects/${slug}.png`,
  `/src/assets/projects/${slug}.webp`,
];

const assetCandidates = preferredAssetPath
  ? [preferredAssetPath, ...fallbackAssetPaths]
  : fallbackAssetPaths;

const resolvedAssetPath = assetCandidates.find((assetPath) => images[assetPath]);
const image = resolvedAssetPath ? images[resolvedAssetPath] : null;
---

<div
  class="group rounded-lg border hover-lift overflow-hidden flex flex-col h-full hover:border-foreground/30"
>
  <div
    class="flex justify-center items-center w-full aspect-video bg-neutral-900 text-white border-b relative overflow-hidden"
  >
    {
      image ? (
        <Image
          src={image}
          alt={`${title} preview`}
          widths={[400, 600, 700]}
          sizes="(max-width: 640px) 400px, (max-width: 1024px) 600px, 700px"
          format="webp"
          quality={80}
          loading="lazy"
          decoding="async"
          class="object-cover w-full relative z-10 transition-transform duration-500 ease-out group-hover:scale-[1.04]"
        />
      ) : (
        <img
          src="/logo.svg"
          alt="Logo"
          class="size-16 text-background transition-transform duration-500 ease-out group-hover:scale-110 group-hover:rotate-3"
          loading="lazy"
          decoding="async"
        />
      )
    }
  </div>
  <div class="p-2 flex flex-col gap-2 grow">
    <div class="h-full">
      <p class="font-semibold tracking-tight text-base">{title}</p>
      <p class="font-sans text-xs">{description}</p>
    </div>
    <div class="flex gap-1">
      {
        tags.map((tag) => (
          <div class="rounded border font-semibold border-transparent bg-secondary text-secondary-foreground px-1 py-0 text-[10px] font-mono">
            {tag}
          </div>
        ))
      }
    </div>
    <div class="flex gap-2">
      {
        githubUrl && (
          <a
            class="items-center rounded border font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-primary text-primary-foreground shadow hover:bg-primary/80 flex gap-1 px-2 py-1 text-[10px]"
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Source
          </a>
        )
      }
      {
        projectUrl && (
          <a
            class="items-center rounded border font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-primary text-primary-foreground shadow hover:bg-primary/80 flex gap-1 px-2 py-1 text-[10px]"
            href={projectUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Live
          </a>
        )
      }
    </div>
  </div>
</div>
